local function parseTimeString(timeStr)
    if not timeStr or type(timeStr) ~= "string" then
        return nil
    end
    
    local minutes, seconds = timeStr:match("(%d+):(%d+)")
    if minutes and seconds then
        return tonumber(minutes) * 60 + tonumber(seconds)
    end
    
    local secs = tonumber(timeStr)
    if secs then
        return secs
    end
    
    return nil
end

local function getTimeRemaining()
    local success, result = pcall(function()
        local activetableset = ReplicatedStorage:WaitForChild("InternalClientEvents", 1):WaitForChild("GetActiveTableset", 1):Invoke()
        if not activetableset then return nil end
        
        local clock = activetableset:FindFirstChild("Clock")
        if not clock then return nil end
        
        local mainBody = clock:FindFirstChild("MainBody")
        if not mainBody then return nil end
        
        local surfaceGui = mainBody:FindFirstChild("SurfaceGui")
        if not surfaceGui then return nil end
        
        local timeLabel
        if State.playerColor == "w" then
            timeLabel = surfaceGui:FindFirstChild("WhiteTime")
        else
            timeLabel = surfaceGui:FindFirstChild("BlackTime")
        end
        
        if not timeLabel or not timeLabel:IsA("TextLabel") then
            return nil
        end
        
        return parseTimeString(timeLabel.Text)
    end)
    
    return success and result or nil
end

