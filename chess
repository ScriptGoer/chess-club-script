-- TIMING
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local recentMoveTimes = {}

local function isTimeUnique(newTime)
    for _, oldTime in ipairs(recentMoveTimes) do
        if math.abs(newTime - oldTime) < 2.0 then
            return false
        end
    end
    return true
end

local function getChaoticMoveTime(isOpening, timeLeft, eval, previousEval, moveNumber, move, previousMove)
    local minTime, maxTime
    
    -- Default eval to 0 if nil
    eval = eval or 0
    previousEval = previousEval or 0
    
    -- CHECK FOR FORCED MATE FIRST (overrides everything including bullet)
    -- Only instant when WE have mate (positive eval from our perspective)
    if eval >= 100 then
        print(string.format("⚡ FORCED MATE FOR US: INSTANT (eval: +%.0f)", eval))
        return math.random(1, 3) / 10  -- 0.1-0.3s
    end
    
    -- BULLET MODE: Much faster thinking overall
    if State.bulletMode then
        if timeLeft and timeLeft < 5 then
            return 0.1
        end
        minTime = 1
        maxTime = 30
        local finalTime = math.random(minTime, maxTime) / 10
        return finalTime
    end
    
    -- CRITICAL: Less than 2 seconds - INSTANT
    if timeLeft and timeLeft < 2.0 then
        print("⚡ <2s LEFT: INSTANT")
        return 0.1
    end
    
    -- CHECK FOR OTHER OBVIOUS POSITIONS
    local evalChange = math.abs(eval - previousEval)
    local absEval = math.abs(eval)  -- Used later for winning/losing checks
    
    -- TRAP CAPTURE: You set a trap (eval jumped +1.5 on YOUR last move), now capturing
    if State.previousEval and State.evalTwoMovesAgo then
        local trapGain = State.previousEval - State.evalTwoMovesAgo
        if trapGain > 1.5 and move and move:find("x") then
            print(string.format("⚡ TRAP CAPTURE: Last move gained +%.2f, now capturing → INSTANT", trapGain))
            return math.random(1, 3) / 10  -- 0.1-0.3s
        end
    end
    
    -- RECAPTURE PREMOVE: TRUE INSTANT (0ms) when we were expecting it
    if previousMove and move then
        if #previousMove >= 4 and #move >= 4 then
            local prevDest = previousMove:sub(3, 4)
            local moveDest = move:sub(3, 4)
            
            if prevDest == moveDest and move:find("x") then
                if State.expectingRecapture then
                    State.expectingRecapture = false
                    return 0  -- TRUE PREMOVE - 0ms
                else
                    return math.random(1, 3) / 10  -- 0.1-0.3s (regular instant)
                end
            end
        end
    end
    
    if State.expectingRecapture then
        State.expectingRecapture = false
    end
    
    -- CRITICAL: Already winning/losing heavily - play fast always
    if absEval > 2.5 then
        minTime = 1
        maxTime = 20
    
    -- Opponent blundered (eval swing > 0.6) - play fast
    elseif evalChange > 0.6 then
        minTime = 1
        maxTime = 25
    
    -- Moderate advantage (1.5-2.5) - play fairly fast
    elseif absEval > 1.5 then
        minTime = 1
        maxTime = 30  -- 0.1-3s (was 5s)
        print(string.format("⚡ WINNING: eval %.2f", eval))
    
    -- OPENING: Fast theory moves (first 8 moves)
    elseif moveNumber < 8 then
        minTime = 1
        maxTime = 25  -- 0.1-2.5s (was 3s)
        print("📚 OPENING: Fast")
    
    -- OPENING BUT SLOWER: Moves 8-12
    elseif moveNumber < 12 then
        minTime = 1
        maxTime = 50  -- 0.1-5s (was 8s)
    
    -- MIDDLEGAME: Longer thinking but not 40s
    else
        minTime = 2
        maxTime = 100  -- 0.2-10s max (was 15s)
    end
    
    -- TIME PRESSURE: Much faster moves
    if timeLeft then
        if timeLeft < 10 then
            minTime = 1
            maxTime = 20  -- 0.1-2s thinking
        elseif timeLeft < 20 then
            minTime = 1
            maxTime = 40  -- 0.1-4s thinking
        elseif timeLeft < 30 then
            minTime = 2
            maxTime = 60  -- 0.2-6s thinking
        elseif timeLeft < 60 then
            maxTime = math.min(maxTime, 200)
        end
    end
    
    local attempts = 0
    local rawTime
    
    repeat
        rawTime = math.random(minTime, maxTime) / 10
        attempts = attempts + 1
        if attempts > 20 then break end
    until isTimeUnique(rawTime)
    
    table.insert(recentMoveTimes, rawTime)
    if #recentMoveTimes > 5 then
        table.remove(recentMoveTimes, 1)
    end
    
    -- CAP thinking time to prevent timeout
    -- Reserve 2 seconds buffer for reaction time + move submission
    if timeLeft then
        local maxAllowedTime = math.max(0.1, timeLeft - 2.0)
        if rawTime > maxAllowedTime then
            rawTime = maxAllowedTime
            print(string.format("⏱️ CAPPED: %.1fs → %.1fs (time left: %.1fs)", 
                rawTime, maxAllowedTime, timeLeft))
        end
    end
    
    return rawTime
end

local function getReactionTime()
    -- PREMOVE: 0 reaction time when expecting recapture
    if State.expectingRecapture then
        return 0  -- TRUE PREMOVE - no reaction delay
    end
    
    -- Faster reaction under time pressure
    if State.timeRemaining and State.timeRemaining < 10 then
        return math.random(1, 5) / 10  -- 0.1-0.5s
    end
    return math.random(1, 15) / 10  -- 0.1-1.5s (was 0.2-2.0s - faster)
end

