-- MOVE SELECTION
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local function selectMove(fen, moveNumber, pieceCount, timeLeft)
    -- Check opening book first (niche openings)
    local bookMove = getBookMove(fen)
    if bookMove then
        print(string.format("📚 BOOK MOVE: %s", bookMove))
        
        -- Store eval as 0 for book moves (neutral)
        local previousEval = State.currentEval
        State.currentEval = 0
        
        return bookMove, 0, 90, 12, previousEval
    end
    
    -- Get base depth for rating
    local depth = selectDepth(moveNumber, pieceCount, timeLeft)
    
    -- RATING-BASED MISTAKE INJECTION
    -- Lower ratings = more frequent mistakes
    local targetRating = Config.TargetRating
    local roll = math.random(100)
    local moveType = "best"
    
    if targetRating >= 2400 then
        -- Master level: 5% mistakes
        if roll > 95 then
            moveType = "mistake"
            depth = math.max(4, depth - 5)  -- Min depth 4
        end
    elseif targetRating >= 2200 then
        -- Expert: 10% mistakes
        if roll > 90 then
            moveType = "mistake"
            depth = math.max(4, depth - 5)  -- Min depth 4
        end
    elseif targetRating >= 2000 then
        -- Advanced: 15% mistakes (10% suboptimal, 5% mistake)
        if roll > 90 then
            moveType = "suboptimal"
            depth = math.max(4, depth - 3)  -- Min depth 4
        elseif roll > 95 then
            moveType = "mistake"
            depth = math.max(4, depth - 5)  -- Min depth 4
        end
    elseif targetRating >= 1800 then
        -- Intermediate+: 20% mistakes (15% suboptimal, 5% mistake)
        if roll > 85 then
            moveType = "suboptimal"
            depth = math.max(4, depth - 3)  -- Min depth 4
        elseif roll > 95 then
            moveType = "mistake"
            depth = math.max(4, depth - 5)  -- Min depth 4
        end
    elseif targetRating >= 1600 then
        -- Intermediate: 30% mistakes (20% suboptimal, 10% mistake)
        if roll > 80 then
            moveType = "suboptimal"
            depth = math.max(4, depth - 3)  -- Min depth 4
        elseif roll > 90 then
            moveType = "mistake"
            depth = math.max(4, depth - 5)  -- Min depth 4
        end
    elseif targetRating >= 1400 then
        -- Casual: 40% mistakes (25% suboptimal, 15% mistake)
        if roll > 75 then
            moveType = "suboptimal"
            depth = math.max(4, depth - 3)  -- Min depth 4
        elseif roll > 85 then
            moveType = "mistake"
            depth = math.max(4, depth - 5)  -- Min depth 4
        end
    else
        -- Beginner: 50% mistakes (30% suboptimal, 20% mistake)
        if roll > 70 then
            moveType = "suboptimal"
            depth = math.max(4, depth - 3)  -- Min depth 4
        elseif roll > 80 then
            moveType = "mistake"
            depth = math.max(4, depth - 6)  -- Min depth 4
        end
    end
    
    if moveType ~= "best" then
        print(string.format("🎲 Injecting %s move (depth %d → %d)", moveType, selectDepth(moveNumber, pieceCount, timeLeft), depth))
    end
    
    -- Get move at reduced depth (for mistakes)
    local move, eval = getStockfishMove(fen, depth, 1, "playing")
    
    -- SAFETY: If mistake depth failed, retry at normal depth
    if not move and moveType ~= "best" then
        local normalDepth = selectDepth(moveNumber, pieceCount, timeLeft)
        warn(string.format("⚠️ Mistake depth %d failed, retrying at depth %d", depth, normalDepth))
        move, eval = getStockfishMove(fen, normalDepth, 1, "playing")
        depth = normalDepth
        moveType = "best"  -- Fall back to best move
    end
    
    if not move then
        warn("✗ API FAILED - No move returned even at normal depth")
        return nil, 0, 0, 0, 0
    end
    
    local estimatedAccuracy = estimateAccuracyFromDepth(depth, moveNumber, pieceCount)
    
    -- Adjust estimated accuracy based on move type
    if moveType == "suboptimal" then
        estimatedAccuracy = math.max(50, estimatedAccuracy - 15)
    elseif moveType == "mistake" then
        estimatedAccuracy = math.max(30, estimatedAccuracy - 30)
    end
    
    -- Store previous eval before updating
    local previousEval = State.currentEval
    
    State.currentEval = eval or 0
    if State.playerColor == "b" then
        State.currentEval = -State.currentEval
        -- Debug log for mate flip
        if math.abs(eval or 0) >= 100 then
            print(string.format("🔍 FLIPPED for BLACK: %s → %s", tostring(eval), tostring(State.currentEval)))
        end
    end
    
    -- Set opening eval baseline (first move)
    if moveNumber == 0 then
        State.openingEval = State.currentEval
    end
    
    return move, State.currentEval, estimatedAccuracy, depth, previousEval
end

