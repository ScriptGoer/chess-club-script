-- CHEATER DETECTION (Background Analysis)
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local function detectCheater(fenBeforeMove, fenAfterMove)
    -- Don't block main thread - run async
    if not Config.Enabled or State.cheaterCheckInProgress then
        return
    end
    
    if State.totalOpponentMoves >= 20 and State.isOpponentCheater then
        -- Already detected, don't waste API calls
        return
    end
    
    State.cheaterCheckInProgress = true
    
    task.spawn(function()
        -- Analyze position BEFORE opponent's move
        -- Get what Stockfish recommends (low depth for speed)
        local depth = 6  -- Fast analysis
        local stockfishMove, stockfishEval = getStockfishMove(fenBeforeMove, depth, 1, "cheater_detection")
        
        if stockfishMove and stockfishEval then
            -- Now get eval of actual position AFTER opponent's move
            local _, actualEval = getStockfishMove(fenAfterMove, depth, 1, "cheater_detection")
            
            if actualEval then
                -- Compare evals (from opponent's perspective)
                -- If opponent's move led to nearly the same eval as Stockfish, they matched
                local evalDiff = math.abs(stockfishEval - actualEval)
                
                -- Match if eval difference is small (<0.3 pawns)
                if evalDiff < 0.3 then
                    State.stockfishMatches = State.stockfishMatches + 1
                end
                
                State.totalOpponentMoves = State.totalOpponentMoves + 1
                
                -- Calculate match rate after 8+ moves
                if State.totalOpponentMoves >= 8 then
                    State.opponentMatchRate = State.stockfishMatches / State.totalOpponentMoves
                    
                    -- Flag as cheater if >85% accuracy
                    if State.opponentMatchRate >= 0.85 and not State.isOpponentCheater then
                        State.isOpponentCheater = true
                        print(string.format("\n⚠️  CHEATER DETECTED: %.0f%% engine accuracy (%d/%d moves)",
                            State.opponentMatchRate * 100,
                            State.stockfishMatches,
                            State.totalOpponentMoves))
                        print("   → Switching to MAX DEPTH (20) to counter\n")
                        
                        Rayfield:Notify({
                            Title = "Cheater Detected",
                            Content = string.format("%.0f%% engine accuracy - Max depth active", 
                                State.opponentMatchRate * 100),
                            Duration = 5,
                        })
                    end
                end
            end
        end
        
        State.cheaterCheckInProgress = false
    end)
end

