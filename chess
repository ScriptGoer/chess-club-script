local function getWhoseTurn(fen)
    if not fen or type(fen) ~= "string" then return nil end
    
    local firstSpace = fen:find(" ")
    if firstSpace then
        local turnChar = fen:sub(firstSpace + 1, firstSpace + 1):lower()
        if turnChar == "w" or turnChar == "b" then
            return turnChar
        end
    end
    
    return nil
end

local function getPieceCount(fen)
    if not fen then return 16 end
    
    local boardPart = fen:match("^([^%s]+)")
    if not boardPart then return 16 end
    
    local count = 0
    for i = 1, #boardPart do
        local char = boardPart:sub(i, i)
        if char:match("[pnbrqkPNBRQK]") then
            count = count + 1
        end
    end
    
    return count
end

local function isOpeningPhase(moveNumber, pieceCount)
    return moveNumber <= 10 and pieceCount >= 28
end

