-- MTCS CALCULATION
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local function calculateMTCS()
    if #State.moveTimesHistory < 3 then
        return 0
    end
    
    local sum = 0
    for _, time in ipairs(State.moveTimesHistory) do
        sum = sum + time
    end
    local mean = sum / #State.moveTimesHistory
    
    local varianceSum = 0
    for _, time in ipairs(State.moveTimesHistory) do
        varianceSum = varianceSum + (time - mean) ^ 2
    end
    local stdDev = math.sqrt(varianceSum / #State.moveTimesHistory)
    
    local coefficientOfVariation = stdDev / mean
    local estimatedMTCS = math.max(0, math.min(100, 100 - (coefficientOfVariation * 100)))
    
    return estimatedMTCS
end

