-- DEPTH SELECTION (with eval-based max depth)
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local function selectDepth(moveNumber, pieceCount, timeLeft)
    -- VS CHEATER: Always use max depth
    if State.isOpponentCheater then
        return 20  -- Max depth to counter engine opponent
    end
    
    -- LOSING: Use max depth to find best defense
    if State.currentEval < 0 then
        return 20  -- Max depth when losing
    end
    
    -- DEPTH BASED ON TARGET RATING
    local targetRating = Config.TargetRating
    local baseDepth
    
    if targetRating >= 2400 then
        baseDepth = math.random(10, 12)
    elseif targetRating >= 2200 then
        baseDepth = math.random(8, 10)
    elseif targetRating >= 2000 then
        baseDepth = math.random(7, 9)
    elseif targetRating >= 1800 then
        baseDepth = math.random(6, 8)
    elseif targetRating >= 1600 then
        baseDepth = math.random(5, 7)
    elseif targetRating >= 1400 then
        baseDepth = math.random(4, 6)
    else
        baseDepth = math.random(3, 5)
    end
    
    -- Complex endgames need slightly higher depth
    if pieceCount < 12 and moveNumber > 30 then
        baseDepth = baseDepth + 1
    end
    
    -- Time pressure: emergency lower depth
    if timeLeft then
        if timeLeft < 3 then
            baseDepth = 4
        elseif timeLeft < 10 then
            baseDepth = math.max(4, baseDepth - 2)
        elseif timeLeft < Config.TimePressureThreshold then
            baseDepth = math.max(5, baseDepth - 1)
        end
    end
    
    return math.max(4, math.min(15, baseDepth))
end

