task.spawn(function()
    while true do
        if State.inGame then
            StatusLabel:Set("Status: ▶ Playing")
            
            if State.playerColor then
                ColorLabel:Set(string.format("Color: %s", State.playerColor == "w" and "White ⚪" or "Black ⚫"))
            end
            
            MoveLabel:Set(string.format("Move: %d/%d", State.moveNumber, State.gameMoveNumber))
            AccuracyLabel:Set(string.format("Accuracy: %.1f%%", State.gameAccuracy))
            
            if #State.depthsUsed > 0 then
                local sum = 0
                for _, d in ipairs(State.depthsUsed) do
                    sum = sum + d
                end
                local avg = sum / #State.depthsUsed
                DepthLabel:Set(string.format("Avg Depth: %.1f", avg))
            end
            
            EvalLabel:Set(string.format("Eval: %s", evalToString(State.currentEval)))
            
            local mtcs = calculateMTCS()
            MTCSLabel:Set(string.format("MTCS: %.0f%%", mtcs))
            
            if State.timeRemaining and State.timeRemaining < Config.TimePressureThreshold then
                TimePressureLabel:Set(string.format("Time Pressure: YES (%.0fs remaining)", 
                    State.timeRemaining))
            else
                TimePressureLabel:Set("Time Pressure: No")
            end
            
            -- Cheater detection status
            if State.isOpponentCheater then
                CheaterLabel:Set(string.format("Opponent: ⚠️ CHEATER (%.0f%%)", State.opponentMatchRate * 100))
            elseif State.totalOpponentMoves >= 8 then
                CheaterLabel:Set(string.format("Opponent: Clean (%.0f%%)", State.opponentMatchRate * 100))
            elseif State.totalOpponentMoves > 0 then
                CheaterLabel:Set(string.format("Opponent: Analyzing... (%d/8 moves)", State.totalOpponentMoves))
            else
                CheaterLabel:Set("Opponent: Waiting for moves...")
            end
        else
            StatusLabel:Set("Status: ⏳ Waiting")
            ColorLabel:Set("Color: —")
            MoveLabel:Set("Move: 0")
            AccuracyLabel:Set("Accuracy: 0%")
            DepthLabel:Set("Avg Depth: 0")
            EvalLabel:Set("Eval: —")
            MTCSLabel:Set("MTCS: 0%")
            TimePressureLabel:Set("Time Pressure: No")
            CheaterLabel:Set("Opponent: —")
        end
        
        task.wait(0.5)
    end
end)

