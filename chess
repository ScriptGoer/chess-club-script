-- ACCURACY ESTIMATION (with time pressure override)
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local function estimateAccuracyFromDepth(depth, moveNumber, pieceCount)
    local baseAccuracy
    
    if depth >= 18 then
        baseAccuracy = 95
    elseif depth >= 15 then
        baseAccuracy = 90
    elseif depth >= 12 then
        baseAccuracy = 87
    elseif depth >= 10 then
        baseAccuracy = 84
    elseif depth >= 8 then
        baseAccuracy = 80
    elseif depth >= 6 then
        baseAccuracy = 75
    else
        baseAccuracy = 70
    end
    
    if isOpeningPhase(moveNumber, pieceCount) then
        baseAccuracy = math.min(98, baseAccuracy + 3)
    end
    
    local variance = math.random(-3, 3)
    
    return math.max(65, math.min(98, baseAccuracy + variance))
end

local function updateGameAccuracy()
    if #State.moveAccuracies == 0 then
        State.gameAccuracy = 0
        return
    end
    
    local sum = 0
    for _, acc in ipairs(State.moveAccuracies) do
        sum = sum + acc
    end
    State.gameAccuracy = sum / #State.moveAccuracies
end

