-- NEW API ROLE SYSTEM (Replace lines 927-1263)

local function getStockfishMove(fen, depth, attemptNumber, apiRole)
    if not requestFunc then
        warn("HTTP not available")
        return nil, nil
    end
    
    attemptNumber = attemptNumber or 1
    apiRole = apiRole or "playing"  -- "playing", "caching", or "cheater_detection"
    
    -- CHECK CACHE FIRST (5-minute timeout)
    local cached = State.moveCache[fen]
    if cached and (tick() - cached.timestamp) < 300 and cached.depth >= depth then
        return cached.move, cached.eval
    end
    
    local timeSince = tick() - State.lastAPICall
    if timeSince < 1.5 then
        task.wait(1.5 - timeSince)
    end
    
    State.lastAPICall = tick()
    
    -- ═══════════════════════════════════════════════════════════
    -- API ROLE SYSTEM (4 APIs with dedicated purposes)
    -- ═══════════════════════════════════════════════════════════
    -- API 1 (chess-api.com): PLAYING - Primary move generation
    -- API 2 (stockfish.online): CACHING - Pre-compute while waiting
    -- API 3 (chess.apurn.com): CHEATER DETECTION - Background analysis
    -- API 4 (lichess.org): BACKUP - Takes over when others fail
    
    local apis = {
        {
            name = "chess-api.com",
            role = "playing",
            url = "https://chess-api.com/v1",
            method = "POST",
            headers = {["Content-Type"] = "application/json"},
            body = HttpService:JSONEncode({fen = fen, depth = depth}),
            parser = function(data)
                if data.move then
                    local eval = nil
                    if data.mate then
                        local mateNum = tonumber(data.mate)
                        eval = mateNum > 0 and 100 or -100
                    elseif data.eval then
                        eval = tonumber(data.eval)
                    elseif data.evaluation then
                        eval = tonumber(data.evaluation)
                    elseif data.score then
                        eval = tonumber(data.score)
                    end
                    
                    return data.move, eval
                end
                return nil, nil
            end
        },
        {
            name = "stockfish.online",
            role = "caching",
            url = string.format("https://stockfish.online/api/s/v2.php?fen=%s&depth=%d&mode=bestmove", 
                (fen:gsub(" ", "%%20")), depth),
            method = "GET",
            headers = {},
            body = nil,
            parser = function(data)
                if data.success and data.bestmove then
                    local move = data.bestmove:match("bestmove%s+(%S+)")
                    if not move then
                        move = data.bestmove
                    end
                    
                    local eval = nil
                    
                    if data.eval then
                        eval = tonumber(data.eval)
                    elseif data.evaluation then
                        eval = tonumber(data.evaluation)
                    elseif data.score then
                        eval = tonumber(data.score)
                    elseif data.mate then
                        local mateNum = tonumber(data.mate)
                        eval = mateNum > 0 and 100 or -100
                    else
                        local cp = data.bestmove:match("score cp ([-%d]+)")
                        if cp then
                            eval = tonumber(cp) / 100
                        else
                            local mate = data.bestmove:match("score mate ([-%d]+)")
                            if mate then
                                local mateNum = tonumber(mate)
                                eval = mateNum > 0 and 100 or -100
                            end
                        end
                    end
                    
                    return move, eval
                end
                return nil, nil
            end
        },
        {
            name = "chess.apurn.com",
            role = "cheater_detection",
            url = "https://chess.apurn.com/nextmove",
            method = "POST",
            headers = {["Content-Type"] = "text/plain"},
            body = fen,
            parser = function(data)
                if data and data.move then
                    local move = data.move
                    local eval = nil
                    
                    if data.eval then
                        eval = tonumber(data.eval)
                    elseif data.evaluation then
                        eval = tonumber(data.evaluation)
                    elseif data.score then
                        eval = tonumber(data.score)
                    end
                    
                    return move, eval
                end
                return nil, nil
            end
        },
        {
            name = "lichess.org",
            role = "backup",
            url = string.format("https://lichess.org/api/cloud-eval?fen=%s&multiPv=1", 
                (fen:gsub(" ", "%%20"))),
            method = "GET",
            headers = {},
            body = nil,
            parser = function(data)
                if data.pvs and #data.pvs > 0 then
                    local pv = data.pvs[1]
                    if pv.moves and #pv.moves > 0 then
                        local move = pv.moves:match("(%S+)")
                        local eval = nil
                        
                        if pv.mate then
                            local mateNum = tonumber(pv.mate)
                            eval = mateNum > 0 and 100 or -100
                        elseif pv.cp then
                            eval = tonumber(pv.cp) / 100
                        end
                        
                        return move, eval
                    end
                end
                return nil, nil
            end
        }
    }
    
    -- Helper function to try an API with timeout
    local function tryAPI(api, apiIndex)
        local success, response = false, nil
        local completed = false
        local requestThread
        
        requestThread = task.spawn(function()
            local reqSuccess, reqResponse = pcall(function()
                if api.method == "POST" then
                    return requestFunc({
                        Url = api.url,
                        Method = "POST",
                        Headers = api.headers,
                        Body = api.body
                    })
                else
                    return requestFunc({
                        Url = api.url,
                        Method = "GET"
                    })
                end
            end)
            
            if not completed then
                completed = true
                success = reqSuccess
                response = reqResponse
            end
        end)
        
        -- Wait up to 8 seconds for response
        local timeout = 8
        local startTime = tick()
        while not completed and (tick() - startTime) < timeout do
            task.wait(0.1)
        end
        
        if not completed then
            completed = true
            task.cancel(requestThread)
            return false, nil, nil
        end
        
        if not success or not response then
            return false, nil, nil
        end
        
        local parseSuccess, data = pcall(function()
            return HttpService:JSONDecode(response.Body)
        end)
        
        if not parseSuccess or not data then
            return false, nil, nil
        end
        
        local move, eval = api.parser(data)
        
        if move then
            -- Cache the result
            State.moveCache[fen] = {
                move = move,
                eval = eval,
                depth = depth,
                timestamp = tick()
            }
            
            return true, move, eval
        end
        
        return false, nil, nil
    end
    
    -- Track which APIs have failed
    local failedAPIs = {}
    
    -- PRIORITY 1: Try API for requested role
    for i, api in ipairs(apis) do
        if api.role == apiRole then
            local success, move, eval = tryAPI(api, i)
            if success then
                return move, eval
            end
            failedAPIs[i] = true
        end
    end
    
    -- PRIORITY 2: Try backup API (lichess)
    for i, api in ipairs(apis) do
        if api.role == "backup" and not failedAPIs[i] then
            local success, move, eval = tryAPI(api, i)
            if success then
                return move, eval
            end
            failedAPIs[i] = true
        end
    end
    
    -- PRIORITY 3: Try any other API (emergency fallback)
    for i, api in ipairs(apis) do
        if not failedAPIs[i] then
            local success, move, eval = tryAPI(api, i)
            if success then
                return move, eval
            end
        end
    end
    
    warn("✗ All APIs failed")
    return nil, nil
end

