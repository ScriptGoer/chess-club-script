-- MOVE PRECOMPUTATION (reduce API wait time)
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local function precomputeNextMove(currentFEN)
    if State.precomputeInProgress or State.lastPrecomputeFEN == currentFEN then
        return  -- Already precomputing or already done for this position
    end
    
    State.precomputeInProgress = true
    State.lastPrecomputeFEN = currentFEN
    
    task.spawn(function()
        task.wait(0.3)
        
        local depth = selectDepth(State.moveNumber + 1, getPieceCount(currentFEN), State.timeRemaining)
        
        -- Use CACHING API for precompute
        local ourMove, eval = getStockfishMove(currentFEN, depth, 1, "caching")
        
        State.precomputeInProgress = false
    end)
end

-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════
-- GAME FUNCTIONS
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local function makeMove(move, moveAccuracy, depth)
    if not move or #move < 4 then
        return false
    end
    
    local success, result = pcall(function()
        return ReplicatedStorage:WaitForChild("Chess", 2):WaitForChild("SubmitMove", 2):InvokeServer(move)
    end)
    
    if success and result == true then
        State.lastMove = move  -- Store for recapture detection
        State.moveNumber = State.moveNumber + 1
        State.gameMoveNumber = State.gameMoveNumber + 1
        
        table.insert(State.moveAccuracies, moveAccuracy)
        if #State.moveAccuracies > 20 then
            table.remove(State.moveAccuracies, 1)
        end
        updateGameAccuracy()
        
        table.insert(State.depthsUsed, depth)
        if #State.depthsUsed > 20 then
            table.remove(State.depthsUsed, 1)
        end
        
        return true
    end
    
    return false
end

local function isOurTurn(fen)
    if not State.playerColor then return nil end
    local currentTurn = getWhoseTurn(fen)
    return currentTurn == State.playerColor
end

-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════
-- MOVE PROCESSING (called when FEN changes)
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════
-- MAIN MOVE PROCESSING
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local function processMoveIfOurTurn(fen)
    if not Config.Enabled then return end
    if not State.inGame then return end
    if not State.playerColor then return end
    
    -- Check if it's our turn
    local ourTurn = isOurTurn(fen)
    
    if not ourTurn then
        if fen ~= State.lastFEN then
            -- Opponent just moved - store position BEFORE their move
            if State.lastFEN then
                State.opponentFENBeforeMove = State.lastFEN
            end
            
            State.gameMoveNumber = State.gameMoveNumber + 1
            State.lastFEN = fen
            
            -- No bot detection when it's opponent's turn
        end
        return
    end
    
    if fen == State.lastFEN then
        return
    end
    
    State.lastFEN = fen
    State.timeRemaining = getTimeRemaining()
    
    -- Spawn processing in separate thread to not block listener
    task.spawn(function()
        local reactionTime = getReactionTime()
        print(string.format("\n═══ MOVE %d ═══", State.moveNumber + 1))
        if State.timeRemaining then
            print(string.format("⏱️ Time: %.1fs", State.timeRemaining))
        end
        
        -- CHEATER DETECTION (background, doesn't block our move)
        if State.opponentFENBeforeMove and State.moveNumber > 0 then
            -- Get what Stockfish recommends from opponent's position
            task.spawn(function()
                detectCheater(State.opponentFENBeforeMove, fen)
            end)
        end
        
        task.wait(reactionTime)
        
        local pieceCount = getPieceCount(fen)
        local isOpening = isOpeningPhase(State.moveNumber, pieceCount)
        
        -- PREMOVE CHECK: If we have a cached move and it's good, play instantly
        local cached = State.moveCache[fen]
        if cached and (tick() - cached.timestamp) < 300 then
            -- Check if cached move is safe (not losing)
            if cached.eval and cached.eval > -1.5 then
                print(string.format("⚡ PREMOVE: Playing cached move %s (eval: %.1f)", cached.move, cached.eval))
                
                local success = makeMove(cached.move, 85, cached.depth)
                if success then
                    State.currentEval = cached.eval
                    if State.playerColor == "b" then
                        State.currentEval = -State.currentEval
                    end
                    
                    -- Update state
                    State.evalTwoMovesAgo = State.previousEval
                    State.previousEval = cached.eval
                    
                    -- Trigger next precompute
                    precomputeNextMove(fen)
                    
                    print(string.format("📊 Premove (depth %d) | Eval: %+.1f", cached.depth, State.currentEval))
                    return  -- Exit early, move already made
                else
                    warn("⚠️ Cached move was illegal, computing new move...")
                end
            else
                warn(string.format("⚠️ Cached move rejected (eval: %.1f too low)", cached.eval or 0))
            end
        end
        
        -- EMERGENCY: If exactly 1s, make any move without API
        local move, eval, moveAcc, depth, previousEval
        
        if State.timeRemaining and State.timeRemaining == 1 then
            warn("🚨 EMERGENCY: 1s left - trying random moves without API")
            
            -- Try common moves in order until one works
            local emergencyMoves = {
                "e2e4", "e7e5", "d2d4", "d7d5", "g1f3", "g8f6",
                "b1c3", "b8c6", "f1c4", "f8c5", "c2c4", "c7c5",
                "e1g1", "e8g8",  -- Castling
                "a2a3", "a7a6", "h2h3", "h7h6"  -- Pawn moves
            }
            
            for _, tryMove in ipairs(emergencyMoves) do
                local success, result = pcall(function()
                    return ReplicatedStorage:WaitForChild("Chess", 2):WaitForChild("SubmitMove", 2):InvokeServer(tryMove)
                end)
                
                if success and result == true then
                    print(string.format("✓ EMERGENCY MOVE: %s (no API)", tryMove))
                    move = tryMove
                    eval = 0
                    moveAcc = 30  -- Very low accuracy
                    depth = 0
                    previousEval = State.currentEval
                    
                    -- Update state
                    State.lastMove = move
                    State.moveNumber = State.moveNumber + 1
                    State.gameMoveNumber = State.gameMoveNumber + 1
                    return  -- Exit early, don't process normally
                end
            end
            
            warn("🚨 EMERGENCY FAILED: No moves worked, will lose on time")
            return
        end
        
        -- Normal move selection
        move, eval, moveAcc, depth, previousEval = selectMove(fen, State.moveNumber, pieceCount, State.timeRemaining)
        
        if not move then
            warn("✗ Stockfish API FAILED - All retries exhausted")
            Rayfield:Notify({
                Title = "API Error",
                Content = "Failed to get move from API",
                Duration = 3,
            })
            return
        end
        
        print(string.format("🤖 Depth %d (acc: %.1f%% | rating: %d)", 
            depth, State.gameAccuracy, Config.TargetRating))
        
        print(string.format("📊 Estimated: %.1f%% | Eval: %s", moveAcc, evalToString(eval)))
        
        local thinkTime = getChaoticMoveTime(isOpening, State.timeRemaining, eval, previousEval, State.moveNumber, move, State.lastMove)
        
        print(string.format("🤔 Think: %.1fs", thinkTime))
        
        table.insert(State.moveTimesHistory, reactionTime + thinkTime)
        if #State.moveTimesHistory > 20 then
            table.remove(State.moveTimesHistory, 1)
        end
        
        -- Check instant mode (overrides all timing)
        if State.instantMode then
            print("⚡ INSTANT MODE: Moving immediately")
            thinkTime = 0.1
        end
        
        -- Wait with cancellable task
        if thinkTime > 0 then
            State.thinkingTask = task.spawn(function()
                task.wait(thinkTime)
                State.thinkingTask = nil
            end)
            
            -- Wait for thinking task to complete
            while State.thinkingTask do
                task.wait(0.05)
            end
        end
        
        local success = makeMove(move, moveAcc, depth)
        
        -- AUTO-RETRY if move failed (likely illegal)
        if not success then
            warn(string.format("✗ Move %s FAILED (illegal?), trying different move...", move))
            task.wait(0.3)
            
            -- Get DIFFERENT move by using lower depth (faster + different analysis)
            local retryDepth = math.max(4, depth - 3)
            local retryMove, retryEval = getStockfishMove(fen, retryDepth, 1, "playing")
            
            -- If we got the same move, try even lower depth
            if retryMove == move then
                warn("Got same move, trying even lower depth...")
                retryDepth = math.max(4, retryDepth - 2)
                retryMove, retryEval = getStockfishMove(fen, retryDepth, 1, "playing")
            end
            
            if retryMove and retryMove ~= move then
                print(string.format("🔄 RETRY with different move: %s (depth %d)", retryMove, retryDepth))
                success = makeMove(retryMove, moveAcc, retryDepth)
                
                if success then
                    -- Update with retry move
                    move = retryMove
                    eval = retryEval or 0
                    State.currentEval = eval or 0
                    if State.playerColor == "b" then
                        State.currentEval = -State.currentEval
                    end
                end
            else
                warn("✗ Retry failed - could not get different move")
            end
        end
        
        if success then
            -- Update eval history for trap detection
            State.evalTwoMovesAgo = State.previousEval  -- Shift history
            State.previousEval = eval  -- Store this move's eval
            
            -- PRECOMPUTE next move while opponent is thinking
            precomputeNextMove(fen)
            
            -- PREMOVE SYSTEM: If we just captured, expect opponent might recapture
            if move:find("x") and eval > -1.0 then
                State.expectingRecapture = true
                print("🎯 Capture made - premove armed for recapture")
            end
            
            -- Classify move type based on eval
            local moveType = "MOVE"
            eval = eval or 0  -- Safety: default to 0 if nil
            previousEval = previousEval or 0  -- Safety: default to 0 if nil
            local evalChange = math.abs(eval - previousEval)
            local absEval = math.abs(eval)
            
            -- Determine move quality
            local quality = ""
            
            -- eval and previousEval are already from player's perspective
            local evalGain = eval - previousEval
            
            if evalGain > 2.0 then
                quality = "‼️ BRILLIANT"  -- Forcing advantage
            elseif evalGain > 0.5 then
                quality = "✓ EXCELLENT"
            elseif evalGain > 0 then
                quality = "✓ GOOD"
            elseif evalGain > -0.25 then
                quality = "BEST"
            elseif evalGain > -0.5 then
                quality = "?! INACCURACY"
            elseif evalGain > -1.0 then
                quality = "? MISTAKE"
            else
                quality = "?? BLUNDER"
            end
            
            -- Position assessment
            if absEval > 2.5 then
                moveType = "WINNING"
            elseif evalChange > 0.6 then
                moveType = "PUNISH"
            elseif absEval > 1.5 then
                moveType = "ADVANTAGE"
            elseif State.moveNumber < 8 then
                moveType = "OPENING"
            end
            
            local evalStr = evalToString(eval)
            print(string.format("✓ %s [%s] %s | %s", quality, moveType, move, evalStr))
        else
            warn("✗ Illegal")
        end
    end)
end

-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════
-- FEN CHANGE LISTENER (EVENT-DRIVEN)
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local function setupFENListener()
    -- Disconnect old listener if exists
    if State.fenConnection then
        State.fenConnection:Disconnect()
        State.fenConnection = nil
    end
    
    local success, result = pcall(function()
        local activetableset = ReplicatedStorage:WaitForChild("InternalClientEvents", 1):WaitForChild("GetActiveTableset", 1):Invoke()
        if not activetableset then return false end
        
        local fenValue = activetableset:FindFirstChild("FEN")
        if not fenValue then return false end
        
        -- Listen for FEN changes
        State.fenConnection = fenValue:GetPropertyChangedSignal("Value"):Connect(function()
            local newFEN = fenValue.Value
            print(string.format("[FEN CHANGED] %s", newFEN:sub(1, 30)))
            processMoveIfOurTurn(newFEN)
        end)
        
        print("✓ FEN listener connected")
        
        -- Process current FEN immediately
        processMoveIfOurTurn(fenValue.Value)
        
        return true
    end)
    
    if not success or not result then
        warn("Failed to setup FEN listener")
        return false
    end
    
    return true
end

-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════
-- GAME DETECTION LOOP (lightweight)
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local function gameDetectionLoop()
    while true do
        task.wait(0.5)  -- Check for new game every 0.5s (faster detection)
        
        if Config.Enabled then
            -- Check if we're in a game
            local success, activetableset = pcall(function()
                return ReplicatedStorage:WaitForChild("InternalClientEvents", 1):WaitForChild("GetActiveTableset", 1):Invoke()
            end)
            
            local inGame = success and activetableset ~= nil
        
        if inGame and not State.inGame then
            -- New game started
            State.inGame = true
            State.moveNumber = 0
            State.gameMoveNumber = 0
            State.lastFEN = nil
            State.lastMove = nil
            State.playerColor = nil
            State.currentEval = 0
            State.previousEval = 0
            State.evalTwoMovesAgo = 0
            State.openingEval = 0
            State.expectingRecapture = false
            State.thinkingTask = nil  -- Clear thinking task
            State.moveAccuracies = {}
            State.gameAccuracy = 0
            State.moveTimesHistory = {}
            State.depthsUsed = {}
            recentMoveTimes = {}
            State.workingAPI = nil  -- Reset sticky API
            State.apiFailCount = 0
            
            -- Reset cheater detection
            State.opponentFENBeforeMove = nil
            State.opponentMoveUCI = nil
            State.stockfishMatches = 0
            State.totalOpponentMoves = 0
            State.opponentMatchRate = 0
            State.isOpponentCheater = false
            State.cheaterCheckInProgress = false
            
            print("\n[NEW GAME] Event-Driven Detection")
            
            -- CRITICAL: Wait 2-3.5s before making first move (prevents instant ban)
            local startDelay = math.random(20, 35) / 10  -- 2.0-3.5s (was 3-5s)
            print(string.format("⏳ Waiting %.1fs before first move (anti-detection)", startDelay))
            task.wait(startDelay)
            
            -- DETECT BULLET MODE (≤60s starting time)
            local startTime = getTimeRemaining()
            if startTime and startTime <= 60 then
                State.bulletMode = true
                print(string.format("⚡ BULLET MODE DETECTED (%.0fs start time)", startTime))
            else
                State.bulletMode = false
            end
            
            Rayfield:Notify({
                Title = "Game Started",
                Content = State.bulletMode and "Bullet Mode" or "Listening for FEN changes",
                Duration = 2,
            })
            
            -- Detect color (no wait - new game detection is delayed anyway)
            local fenValue = activetableset:FindFirstChild("FEN")
            if fenValue then
                local fen = fenValue.Value
                local turn = getWhoseTurn(fen)
                
                -- Try making a move to detect color
                local move, _ = getStockfishMove(fen, 12, 1, "playing")
                if move then
                    local success = makeMove(move, 90, 12)
                    if success then
                        State.playerColor = turn
                        State.moveNumber = 1
                        State.gameMoveNumber = turn == "w" and 1 or 2
                    else
                        State.playerColor = turn == "w" and "b" or "w"
                        State.moveNumber = 0
                        State.gameMoveNumber = turn == "w" and 2 or 1
                    end
                    
                    print(string.format("✓ Playing as %s", State.playerColor == "w" and "White" or "Black"))
                    
                    Rayfield:Notify({
                        Title = State.playerColor == "w" and "White ⚪" or "Black ⚫",
                        Content = "FEN change detection active",
                        Duration = 3,
                    })
                end
            end
            
            -- Setup FEN listener
            setupFENListener()
            
        elseif not inGame and State.inGame then
            -- Game ended
            State.inGame = false
            State.workingAPI = nil
            State.apiFailCount = 0
            
            if State.fenConnection then
                State.fenConnection:Disconnect()
                State.fenConnection = nil
            end
            
            local finalMTCS = calculateMTCS()
            
            local avgDepth = 0
            if #State.depthsUsed > 0 then
                local sum = 0
                for _, d in ipairs(State.depthsUsed) do
                    sum = sum + d
                end
                avgDepth = sum / #State.depthsUsed
            end
            
            print(string.format("\n[GAME ENDED] Moves: %d | Accuracy: %.1f%% | Avg Depth: %.1f | MTCS: %.0f%%", 
                State.moveNumber, State.gameAccuracy, avgDepth, finalMTCS))
            
            Rayfield:Notify({
                Title = "Game Ended",
                Content = string.format("Acc: %.1f%% | Depth: %.1f", State.gameAccuracy, avgDepth),
                Duration = 5,
            })
            
            State.playerColor = nil
            State.moveNumber = 0
            State.gameMoveNumber = 0
            State.lastMove = nil
            State.previousEval = 0
            State.evalTwoMovesAgo = 0
            State.openingEval = 0
            State.expectingRecapture = false
            State.bulletMode = false
            State.thinkingTask = nil  -- Clear thinking task
            
            -- RAPID REMATCH DETECTION: Check every 0.2s for 10s after game ends
            print("🔍 Rapid rematch detection active (10s)")
            task.spawn(function()
                for i = 1, 50 do  -- 50 x 0.2s = 10s
                    task.wait(0.2)
                    
                    local success, activetableset = pcall(function()
                        return ReplicatedStorage:WaitForChild("InternalClientEvents", 1):WaitForChild("GetActiveTableset", 1):Invoke()
                    end)
                    
                    if success and activetableset ~= nil and not State.inGame then
                        print("⚡ Quick rematch detected!")
                        break  -- Let main loop handle it
                    end
                end
            end)
        end
        end  -- Close if Config.Enabled then
    end
end

