-- EVALUATION CONVERSION
-- ────────────────────────────────────────────────────────────══════════════════════════════════════════════════════════

local function centipawnsToWinProbability(centipawns)
    -- Formula used by chess engines
    -- Win% = 50 + 50 * (2 / (1 + exp(-0.00368208 * cp)) - 1)
    local normalized = 2 / (1 + math.exp(-0.00368208 * centipawns)) - 1
    return 50 + 50 * normalized
end

local function evalToString(eval)
    -- eval is already adjusted for player's perspective in State.currentEval
    
    -- Check for mate
    if math.abs(eval) >= 100 then
        if eval > 0 then
            return "M (forced mate for us)"
        else
            return "-M (forced mate for opponent)"
        end
    end
    
    -- Normal eval display
    if eval > 0 then
        return string.format("+%.2f", eval)
    else
        return string.format("%.2f", eval)
    end
end

